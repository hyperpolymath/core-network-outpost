# SPDX-License-Identifier: MPL-2.0
# Copy to .env and edit. Keep .env out of git (see .gitignore).
#
# NOTE: the AdGuard Home image is NOT set here. Its pinned digest is the
# committed base in ../images.lock and is changed only via `bin/bump.sh`.
# This file is for local, machine-specific values only.

# --- Localisation -------------------------------------------------------------
TZ=Europe/London

# --- Network ------------------------------------------------------------------
# Your LAN subnet in CIDR. Used by the firewall + CUPS + AdGuard access rules.
LAN_SUBNET=192.168.1.0/24

# SSH port for the host (set to a non-22 port to cut scanner noise; update
# host/nftables.nft to match). Leave 22 if you prefer.
SSH_PORT=22
