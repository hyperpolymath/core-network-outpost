# SPDX-License-Identifier: MPL-2.0
# Copy to .env and edit. Keep .env out of git (see .gitignore).
#
# NOTE: the AdGuard Home image is NOT set here. Its pinned digest is the
# committed base in ../images.lock and is changed only via `bin/bump.sh`.
# This file is for local, machine-specific values only.

# --- Localisation -------------------------------------------------------------
TZ=Europe/London

# --- Network ------------------------------------------------------------------
# Your LAN subnet in CIDR. Used by the firewall + CUPS + AdGuard access rules.
LAN_SUBNET=192.168.1.0/24

# SSH port for the host (set to a non-22 port to cut scanner noise; update
# host/nftables.nft to match). Leave 22 if you prefer.
SSH_PORT=22

# --- Dynamic DNS (optional) ---------------------------------------------------
# Gives the outpost a stable name even though your ISP moves your IP around.
#
# Provider-agnostic: any "dyndns2" provider works (Dynu, DuckDNS, No-IP, ...).
# The default endpoint below is Dynu because that is what this was built and
# tested against. That is an EXAMPLE, not an endorsement — repoint it freely.
#
# SECRETS: DDNS_PASSWORD is a scoped, revocable, single-purpose credential for
# updating ONE dns record. It is NOT a personal password and must never be a
# reused one. It lives here in .env only — .env is gitignored. Never commit it.
# After editing:   chmod 600 .env
DDNS_ENABLED=false
DDNS_HOSTNAME=outpost.example.dynu.net
DDNS_USERNAME=your-provider-username
DDNS_PASSWORD=your-provider-ddns-password-or-api-key
DDNS_UPDATE_URL=https://api.dynu.com/nic/update
DDNS_IP_LOOKUP=https://api.ipify.org
# Providers expire records that are never refreshed (Dynu: ~30 days). Re-announce
# this often even when the IP has not changed.
DDNS_MAX_AGE_DAYS=25
