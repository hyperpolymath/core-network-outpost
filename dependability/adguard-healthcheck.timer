# /etc/systemd/system/adguard-healthcheck.timer
# Enable:  systemctl enable --now adguard-healthcheck.timer
[Unit]
Description=Probe AdGuard DNS liveness every 30s

[Timer]
OnBootSec=60
OnUnitActiveSec=30
AccuracySec=5s

[Install]
WantedBy=timers.target
