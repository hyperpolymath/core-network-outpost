# /etc/systemd/system/adguard-healthcheck.service  (Debian/systemd hosts, e.g. N100)
# Alpine/OpenRC 2B: run the script from cron instead — see dependability/README.md.
# VALIDATE:  systemd-analyze verify adguard-healthcheck.service
[Unit]
Description=AdGuard Home DNS liveness self-heal
After=network.target

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/adguard-healthcheck.sh
TimeoutStartSec=30
# Environment=CONTAINER=adguardhome RESOLVER=127.0.0.1
