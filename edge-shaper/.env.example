#
# Copy to .env and fill in. .env is NOT committed (see .gitignore when you graduate this).

# --- Interfaces -------------------------------------------------------------
# WAN = the i226-V 2.5GbE port facing the Virgin Hub (in modem mode).
WAN_IF=enp1s0
# LAN = the i226-V 2.5GbE port facing your switch/AP. Confirm names with `ip -br link`.
LAN_IF=enp2s0

# --- CAKE bandwidth (PLACEHOLDERS — replace with YOUR measured speeds) -------
# Set to ~85% of measured download and ~90% of measured upload (kbit).
# Example below assumes a measured ~350/35 Mbit Virgin line. CHANGE THESE.
DOWN_KBIT=300000
UP_KBIT=32000

# --- CAKE behaviour ---------------------------------------------------------
# DOCSIS overhead preset for cable (overhead 18, mpu 64). Leave as-is on Virgin.
OVERHEAD_PRESET=docsis
# besteffort (ignore DSCP, safest) | diffserv4 (honour marks — only if you mark).
EGRESS_DIFFSERV=besteffort
# LAN subnet the router hands out / masquerades (used by nftables.nft).
LAN_SUBNET=192.168.1.0/24
